# Supabase — use a chave SERVICE ROLE (nunca a anon key) nas funções de API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — API key para envio de e-mails
RESEND_API_KEY=re_...

# URL pública da aplicação (sem barra no final)
# Em desenvolvimento: http://localhost:3000  (use "vercel dev")
# Em produção: https://SEU-PROJETO.vercel.app
APP_URL=http://localhost:3000

# Lista de gestores aprovadores (alternativa ao config/approvers.json no Vercel)
# Separados por vírgula, sem espaços
# APPROVERS_LIST=gestor@taclashopping.com.br,rh@taclashopping.com.br
