# Supabase — use a chave SERVICE ROLE (nunca a anon key) nas funções de API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — API key para envio de e-mails
RESEND_API_KEY=re_...

# URL pública da aplicação (sem barra no final)
# Em desenvolvimento: http://localhost:3000  (use "vercel dev")
# Em produção: https://SEU-PROJETO.vercel.app
APP_URL=http://localhost:3000

# ── Painel de gestores ────────────────────────────────────────────────────────

# Senha compartilhada para login no painel /admin
ADMIN_PASSWORD=senha-segura-aqui

# Segredo para assinar tokens de sessão JWT (string aleatória longa)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=string-aleatoria-longa-aqui

# ── Aprovadores por empresa ───────────────────────────────────────────────────
# JSON com mapa domínio → array de e-mails dos gestores aprovadores.
# Cada gestor só vê e aprova solicitações da sua própria empresa.
#
# IMPORTANTE: use aspas simples no .env.local para evitar problemas com o JSON.
#
COMPANY_APPROVERS='{"taclashopping.com.br":["gestor@taclashopping.com.br"],"palladiumcuritiba.com.br":["gestor@palladiumcuritiba.com.br"],"palladiumumuarama.com.br":["gestor@palladiumumuarama.com.br"],"palladiumpontagrossa.com.br":["gestor@palladiumpontagrossa.com.br"],"catuaipalladium.com.br":["gestor@catuaipalladium.com.br"],"itajaishopping.com.br":["gestor@itajaishopping.com.br"],"outletportobelo.com.br":["gestor@outletportobelo.com.br"],"citycenteroutlet.com.br":["gestor@citycenteroutlet.com.br"],"venturashopping.com.br":["gestor@venturashopping.com.br"],"shoppingestacao.com.br":["gestor@shoppingestacao.com.br"],"jockeyplaza.com.br":["gestor@jockeyplaza.com.br"],"shoppingcidadesorocaba.com.br":["gestor@shoppingcidadesorocaba.com.br"],"plazacamposgerais.com.br":["gestor@plazacamposgerais.com.br"]}'
